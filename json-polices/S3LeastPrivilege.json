{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "AllowSpecificS3Access",
            "Effect": "Allow",
            "Action": [
                "s3:GetObject",
                "s3:ListBucket"
            ],
            "Resource": [
                "arn:aws:s3:::my-app-data-bucket",
                "arn:aws:s3:::my-app-data-bucket/data/*"
            ]
        },
        {
            "Sid": "ExplicitDenyOtherS3",
            "Effect": "Deny",
            "Action": "s3:*",
            "Resource": "arn:aws:::s3:*"
        }
    ]
}