{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "AllowLambdaS3Write",
            "Effect": "Allow",
            "Action": "s3:PutObject",
            "Resource": [
                "arn:aws:s3:::log-bucket/logs/*"
            ],
            "Condition": {
                "StringEquals": {
                    "aws:RequestedRegion": "ap-south-1"
                },
                "IpAddress": {
                    "aws:SourceIp": "203.0.113.0/24"
                }
            }
        }
    ]
}